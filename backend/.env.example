APP_NAME=Team Issue Tracker API
APP_ENV=development

DATABASE_URL=postgresql+asyncpg://issue_user:issue_password@localhost:5432/issue_tracker
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=replace-with-access-token-secret
JWT_REFRESH_SECRET_KEY=replace-with-refresh-token-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=7
SQL_ECHO=false

REDIS_DEFAULT_TTL_SECONDS=300
REDIS_HEALTHCHECK_TIMEOUT_SECONDS=3

AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_REGISTER_MAX_ATTEMPTS=3
AUTH_RATE_LIMIT_REFRESH_MAX_ATTEMPTS=10

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-password

# Email (set EMAILS_ENABLED=true in production)
EMAILS_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@issuetracker.example.com
SMTP_FROM_NAME=Issue Tracker
SMTP_USE_TLS=true
EMAIL_VERIFY_TOKEN_EXPIRES_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRES_HOURS=1

# File storage: "local" for dev, "s3" for production
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# AWS S3 (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
S3_PRESIGNED_URL_EXPIRES_SECONDS=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
